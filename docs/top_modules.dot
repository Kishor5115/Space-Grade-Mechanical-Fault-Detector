digraph G {
    fontname="Courier";
    fontsize=20;
    fontcolor="#00E5FF";
    label="TOP MODULE CONNECTIONS (GF180 ASIC)";
    labelloc="t";
    
    // Overall settings for aspect ratio and dark background
    ratio="fill";
    size="16,9!";
    splines=ortho;
    nodesep=0.7;
    ranksep=1.0;
    rankdir=LR;
    bgcolor="#08101E"; // Dark blue background like system_architecture.png

    node [shape=record, style="rounded,filled", fillcolor="#111B2D", color="#00E5FF", fontcolor="#FFFFFF", fontname="Courier", penwidth=2, fontsize=12];
    edge [fontname="Courier", fontsize=10, color="#00E5FF", fontcolor="#A0C0FF", penwidth=2];

    subgraph cluster_inputs {
        label="EXTERNAL INPUTS";
        color="#888888"; fontcolor="#888888"; penwidth=2; style="rounded";
        margin=20;
        
        sensor_drdy [shape=ellipse, fillcolor="#182A40", color="#FFB000", label="sensor_drdy"];
        c_miso [shape=ellipse, fillcolor="#182A40", color="#FFB000", label="c_miso"];
        tmr_forward_en [shape=ellipse, fillcolor="#182A40", color="#FFB000", label="tmr_forward_en"];
    }

    subgraph cluster_top {
        label="GF180 ASIC - INTERNAL MODULES";
        color="#00E5FF"; fontcolor="#00E5FF"; penwidth=2; style="rounded";
        margin=30;
        
        // Modules
        spi_apb_inst [label="{ SPI_APB_INTERFACE | SPI Master + APB Mux }", height=1.5, width=3];
        tmr_inst [label="{ TMR_REG_BANK | Triplicated Config & Status }", height=1.5, width=3];
        
        axseq_inst [label="{ AXIS_SEQUENCER | Polls SPI, Feeds Core }", height=1.5, width=3];
        goertzel_inst [label="{ GOERTZEL_CORE | 3-Bin Time-Multiplexed DSP }", height=1.5, width=3];
        
        mag_inst [label="{ MAGNITUDE_COMPUTE | Shared Multiplier + Mag Block }", height=1.5, width=3];
        ff_inst [label="{ FAULT_FLAGGER | Threshold Comparator }", height=1.5, width=3, color="#FF007F"];
        
        // Force layout structure
        { rank=same; spi_apb_inst; tmr_inst }
        { rank=same; axseq_inst; mag_inst }
        { rank=same; goertzel_inst; ff_inst }
    }

    subgraph cluster_outputs {
        label="EXTERNAL OUTPUTS";
        color="#888888"; fontcolor="#888888"; penwidth=2; style="rounded";
        margin=20;
        
        c_csn [shape=ellipse, fillcolor="#182A40", color="#00FF00", label="c_csn"];
        c_sclk [shape=ellipse, fillcolor="#182A40", color="#00FF00", label="c_sclk"];
        c_mosi [shape=ellipse, fillcolor="#182A40", color="#00FF00", label="c_mosi"];
        fault_flag_out [shape=ellipse, fillcolor="#182A40", color="#FF007F", fontcolor="#FF007F", label="fault_flag_out"];
    }

    // Connections - Inputs (Yellow-ish edges)
    sensor_drdy -> spi_apb_inst [color="#FFB000"];
    c_miso -> spi_apb_inst [color="#FFB000"];
    tmr_forward_en -> spi_apb_inst [color="#FFB000"];
    
    // Connections - Outputs (Green/Pink edges)
    spi_apb_inst -> c_csn [color="#00FF00"];
    spi_apb_inst -> c_sclk [color="#00FF00"];
    spi_apb_inst -> c_mosi [color="#00FF00"];

    // Inter-module connections
    spi_apb_inst -> tmr_inst [dir=both, color="#00E5FF"];
    spi_apb_inst -> axseq_inst [dir=both, color="#00E5FF"];

    tmr_inst -> goertzel_inst [style=dashed, color="#A0C0FF"];
    tmr_inst -> mag_inst [style=dashed, color="#A0C0FF"];
    tmr_inst -> axseq_inst [style=dashed, color="#A0C0FF"];
    tmr_inst -> ff_inst [style=dashed, color="#A0C0FF"];

    axseq_inst -> goertzel_inst [color="#00E5FF"];
    axseq_inst -> mag_inst [color="#00E5FF"];
    axseq_inst -> ff_inst [color="#00E5FF"];

    goertzel_inst -> mag_inst [dir=both, color="#FFB000"];
    goertzel_inst -> ff_inst [color="#00E5FF"];

    mag_inst -> ff_inst [color="#00FF00"];

    ff_inst -> tmr_inst [color="#FF007F"];
    ff_inst -> fault_flag_out [color="#FF007F", penwidth=3];
}
